{
  "name": "ai-resume-tailor",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "setup:env": "test -f .env && echo '.env already exists — skipped' || (cp .env.example .env && echo 'Created .env — add your GEMINI_API_KEY')",
    "setup": "bun run setup:env",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/vercel": "^11.0.2",
    "@astrojs/vue": "^7.0.1",
    "@google/generative-ai": "^0.24.1",
    "astro": "^7.0.6",
    "cheerio": "^1.1.2",
    "fflate": "^0.8.2",
    "googleapis": "^173.0.0",
    "jspdf": "^4.2.1",
    "mammoth": "^1.12.0",
    "unpdf": "^1.6.2",
    "vue": "^3.5.39",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^9.39.2",
    "@types/node": "^26.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^17.7.0",
    "prettier": "^3.6.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.2",
    "vitest": "^3.2.4"
  }
}
