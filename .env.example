# Get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional — API model id (not the UI label). Rotation order on quota errors:
# gemini-3.5-flash → gemini-3.1-flash-lite → gemini-3-flash-preview →
# gemini-2.5-pro → gemini-2.5-flash → gemini-2.5-flash-lite
# GEMINI_MODEL=gemini-3.1-flash-lite
# Free tier quotas differ per model — if you get 429, try another model or enable billing:
# https://ai.google.dev/gemini-api/docs/rate-limits

# Optional — custom prompt file path (defaults to prompts/tailor-resume.prompt)
# Ignored when GEMINI_PROMPT is set.
# GEMINI_PROMPT_PATH=prompts/tailor-resume.prompt

# Optional — full prompt text (takes priority over GEMINI_PROMPT_PATH).
# Useful on Vercel: paste the entire prompt as a multiline env var.
# Must include {{JOB_DESCRIPTION}} and {{RESUME_TEXT}} placeholders.
# GEMINI_PROMPT=
